# Flowmate environment variables.
#
# v1 runs against the local Supabase stack (`supabase start`). Copy this file to
# `.env` and fill in the values printed by `supabase start` (or `supabase
# status`). No secrets are committed; EXPO_PUBLIC_* vars are inlined at build
# time and the anon key is safe to ship (RLS is the security boundary).
#
# URL: use the host the runtime can reach the local stack on.
#   - Android emulator (WSLg, the v1 run target): http://10.0.2.2:56321
#     (10.0.2.2 is the emulator's alias for the host loopback)
#   - Web / host (`expo start --web`):             http://127.0.0.1:56321
# Flowmate uses the 563xx port range so its stack coexists with other local
# Supabase projects on this host. The anon key below is the standard local
# demo key emitted by `supabase start`; it is identical across local stacks.

EXPO_PUBLIC_SUPABASE_URL=http://10.0.2.2:56321
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
